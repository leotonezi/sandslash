# JS-rendered page detection thresholds.
# Ratio of visible text bytes to total HTML bytes below which a page is
# considered likely JS-rendered. Range: 0.0–1.0. Default: 0.05
JS_RENDERED_TEXT_RATIO_THRESHOLD=0.05

# Minimum number of semantic content tags (p, article, section, main, li,
# h1–h6) required to consider a page content-rich. Default: 3
JS_RENDERED_MIN_CONTENT_TAGS=3
